{
  "manifest_version": 3,
  "name": "Messenger Focus",
  "version": "0.1",

  "background": {
    "service_worker": "dist/background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["dist/content.js"],
      "css": ["src/styles.css"]
    }
  ],

  "permissions": ["tabs", "webNavigation"]
}