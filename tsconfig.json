{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["chrome"],
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "exclude": [
    "eslint.config.*"
  ]
}
